# LiveDoc Backend Configuration
# Copy to .env and fill in your values - DO NOT commit .env with real credentials

# Database (use strong password in production)
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@localhost:5432/livedoc

# Redis (with password for production)
REDIS_URL=redis://:CHANGE_ME@localhost:6379

# CORS Origins (set to your frontend URL in production)
CORS_ORIGINS=["http://localhost:5173"]

# Set to false in production
DEBUG=false
